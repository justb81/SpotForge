# SpotForge Backend – Umgebungsvariablen (Vorlage).
#
# Lokal:  `cp .env.example .env`, Infra via `docker compose -f docker-compose.dev.yml up -d`,
#         Backend via `pnpm --filter @spotforge/backend dev` (läuft auf dem Host).
# Coolify: dieselben Schlüssel als Environment-Variablen der App-Ressource
#          setzen; die Verbindungs-URLs zeigen dort auf die internen Service-
#          Namen (postgres/redis/garage), nicht auf localhost.

# --- Server ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# --- PostgreSQL (Konten, Karten, Battles, Tausch – je appId getrennt) ---
# Zwei Rollen (ADR 0012): RLS greift NICHT für Superuser, daher verbindet der
# Request-Pfad mit einer Nicht-Superuser-Rolle (DATABASE_URL), während
# Migrate-on-boot die Admin-Rolle nutzt (MIGRATION_DATABASE_URL) und die App-
# Rolle dabei idempotent anlegt.
POSTGRES_USER=spotforge
POSTGRES_PASSWORD=spotforge
POSTGRES_DB=spotforge
APP_DB_USER=spotforge_app
APP_DB_PASSWORD=spotforge_app
DATABASE_URL=postgresql://spotforge_app:spotforge_app@localhost:5432/spotforge
MIGRATION_DATABASE_URL=postgresql://spotforge:spotforge@localhost:5432/spotforge

# --- Redis (Refresh-Tokens, später Sessions/Leaderboards/Real-Time) ---
REDIS_URL=redis://localhost:6379

# --- MeiliSearch (Marktplatz-Suche) ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=masterKeyChangeMe

# --- S3 / Garage (opt-in geteilte Kartenbilder; ADR 0013) ---
# Access-Key/Secret stammen aus dem Bootstrap (tools/garage/bootstrap.sh).
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_ACCESS_KEY_ID=changeme-after-bootstrap
S3_SECRET_ACCESS_KEY=changeme-after-bootstrap
S3_BUCKET=spotforge-media

# --- Auth: eigene Access-Tokens ---
JWT_SECRET=change-me-in-production-min-16
JWT_ACCESS_TTL=15m
REFRESH_TTL_SECONDS=2592000

# --- OAuth2: erlaubte Client-IDs (aud) je Anbieter, komma-separiert ---
# Das vom Client gelieferte ID-Token muss eine dieser IDs als Audience tragen.
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=
