# SpotForge Backend – Umgebungsvariablen (Vorlage).
#
# Lokal:  `cp .env.example .env` und mit `docker compose up -d` nutzen.
# Coolify: dieselben Schlüssel als Environment-Variablen der App-Ressource
#          setzen (Verbindungs-URLs zeigen dort auf die Coolify-Ressourcen).

# --- Server ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# --- PostgreSQL (Konten, Karten, Battles, Tausch – je appId getrennt) ---
POSTGRES_USER=spotforge
POSTGRES_PASSWORD=spotforge
POSTGRES_DB=spotforge
DATABASE_URL=postgresql://spotforge:spotforge@localhost:5432/spotforge

# --- Redis (Sessions, Leaderboards, Real-Time) ---
REDIS_URL=redis://localhost:6379

# --- MeiliSearch (Marktplatz-Suche) ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=masterKeyChangeMe

# --- S3 / MinIO (opt-in geteilte Kartenbilder) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=spotforge
S3_SECRET_ACCESS_KEY=spotforge-secret
S3_BUCKET=spotforge-media

# --- Auth ---
JWT_SECRET=change-me-in-production
