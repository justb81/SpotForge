{
  "$schema": "https://json.schemastore.org/tsconfig",
  "//": "Gemeinsame Basis für alle Pakete. Erbt von der Repo-Wurzel-Basis und schaltet",
  "//2": "Emit ab – die Pakete werden source-first konsumiert (Metro bzw. tsup bündeln).",
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  }
}
