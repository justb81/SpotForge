diff --git a/android/build.gradle b/android/build.gradle
index 41b43599a9af6ef1c170047d39db1f3baa6ca682..dd390dada7fad8d0cc6ac8b933525195c076475c 100644
--- a/android/build.gradle
+++ b/android/build.gradle
@@ -247,7 +247,13 @@ dependencies {
     extractLibs "com.microsoft.onnxruntime:onnxruntime-android:latest.integration@aar"
   }
 
-  if (VersionNumber.parse(REACT_NATIVE_VERSION) < VersionNumber.parse("0.71")) {
+  // Gradle 9 hat die interne Klasse org.gradle.util.VersionNumber entfernt
+  // (genutzt von Expo SDK 56). Der fbjni-Sonderfall gilt nur für React Native
+  // < 0.71; wir prüfen den Minor-Versionsteil ohne die entfernte API.
+  def rnVersionParts = REACT_NATIVE_VERSION.tokenize('.-')
+  def rnMajor = rnVersionParts[0].toInteger()
+  def rnMinor = rnVersionParts.size() > 1 ? rnVersionParts[1].toInteger() : 0
+  if (rnMajor == 0 && rnMinor < 71) {
     extractLibs "com.facebook.fbjni:fbjni:+:headers"
     extractLibs "com.facebook.fbjni:fbjni:+"
   }
